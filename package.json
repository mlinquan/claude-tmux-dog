{
  "name": "claude-tmux-dog",
  "version": "0.2.1",
  "description": "Claude Code process manager and inter-agent message bus. Event-driven hooks + background watcher daemons for autonomous agent orchestration.",
  "type": "module",
  "bin": {
    "cdog": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "files": [
    "dist",
    "hooks",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claude",
    "claude-code",
    "tmux",
    "process-manager",
    "agent",
    "agent-orchestration",
    "agent-messaging",
    "message-bus",
    "inter-agent",
    "multi-agent",
    "watchdog",
    "auto-recovery"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SnowAIGirl/claude-tmux-dog.git"
  },
  "bugs": {
    "url": "https://github.com/SnowAIGirl/claude-tmux-dog/issues"
  },
  "authors": [
    "SnowAIGirl (https://github.com/SnowAIGirl)",
    "LinQuan (https://github.com/mlinquan)"
  ],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-notifier": "^8.0.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "dayjs": "^1.11.21",
    "node-notifier": "^10.0.1"
  }
}